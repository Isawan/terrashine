FROM --platform=$BUILDPLATFORM alpine@sha256:865b95f46d98cf867a156fe4a135ad3fe50d2056aa3f25ed31662dff6da4eb62
ARG HOST_BIN_PATH
ARG TARGETARCH
ARG TARGETOS
ARG TARGETPLATFORM
COPY ${HOST_BIN_PATH} /usr/bin/terrashine
ENV RUST_LOG=info
ENV TERRASHINE_HTTP_LISTEN="[::]:9543"
EXPOSE 9543
ENTRYPOINT ["terrashine"]
CMD ["server"]