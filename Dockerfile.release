FROM --platform=$BUILDPLATFORM alpine@sha256:5b10f432ef3da1b8d4c7eb6c487f2f5a8f096bc91145e68878dd4a5019afde11
ARG HOST_BIN_PATH
ARG TARGETARCH
ARG TARGETOS
ARG TARGETPLATFORM
COPY ${HOST_BIN_PATH} /usr/bin/terrashine
ENV RUST_LOG=info
ENV TERRASHINE_HTTP_LISTEN="[::]:9543"
EXPOSE 9543
ENTRYPOINT ["terrashine"]
CMD ["server"]