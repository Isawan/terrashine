FROM --platform=$BUILDPLATFORM alpine@sha256:51183f2cfa6320055da30872f211093f9ff1d3cf06f39a0bdb212314c5dc7375
ARG HOST_BIN_PATH
ARG TARGETARCH
ARG TARGETOS
ARG TARGETPLATFORM
COPY ${HOST_BIN_PATH} /usr/bin/terrashine
ENV RUST_LOG=info
ENV TERRASHINE_HTTP_LISTEN="[::]:9543"
EXPOSE 9543
ENTRYPOINT ["terrashine"]
CMD ["server"]