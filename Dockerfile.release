FROM --platform=$BUILDPLATFORM alpine@sha256:28bd5fe8b56d1bd048e5babf5b10710ebe0bae67db86916198a6eec434943f8b
ARG HOST_BIN_PATH
ARG TARGETARCH
ARG TARGETOS
ARG TARGETPLATFORM
COPY ${HOST_BIN_PATH} /usr/bin/terrashine
ENV RUST_LOG=info
ENV TERRASHINE_HTTP_LISTEN="[::]:9543"
EXPOSE 9543
ENTRYPOINT ["terrashine"]
CMD ["server"]